# =====================================================================
# .env.example  -  ARQUIVO MODELO
# =====================================================================
# Este arquivo de exemplo SIM vai para o GitHub. Ele NAO tem senha real,
# so mostra QUAIS informacoes o sistema precisa.
#
# COMO USAR (cada integrante faz na sua maquina):
#   1. Copie este arquivo e renomeie a copia para ".env"
#   2. No .env, preencha os valores com os dados REAIS da sua maquina
#   3. O .env (com a senha real) NUNCA sobe - ele esta no .gitignore
# =====================================================================

DB_HOST=localhost
DB_PORT=3306
DB_NAME=padaria_db
DB_USER=root
DB_PASSWORD=coloque_sua_senha_aqui
